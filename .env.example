# Copy this file to .env and fill in local values.
# The bootstrap script loads .env automatically and validates required keys.
AGENT_HOME=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)

# LLM provider: builtin.echo, openai, anthropic, deepseek, or ollama.
AGENTOS_LLM_PROVIDER=openai
AGENTOS_LLM_MODEL=gpt-5.4-mini

# OpenAI API credentials. Required when AGENTOS_LLM_PROVIDER=openai.
OPENAI_API_KEY=
# OPENAI_PROJECT_ID=proj_...
# OPENAI_ORG_ID=org_...

# Anthropic API credentials. Required when AGENTOS_LLM_PROVIDER=anthropic.
# ANTHROPIC_API_KEY=

# DeepSeek API credentials. Required when AGENTOS_LLM_PROVIDER=deepseek.
# AGENTOS_LLM_PROVIDER=deepseek
# AGENTOS_LLM_MODEL=deepseek-chat
# AGENTOS_LLM_MODEL_HIGH=deepseek-reasoner
# AGENTOS_LLM_MODEL_MEDIUM=deepseek-chat
# AGENTOS_LLM_MODEL_LOW=deepseek-chat
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_HOST=https://api.deepseek.com

# Ollama endpoint. Used when AGENTOS_LLM_PROVIDER=ollama or when provider is inferred from OLLAMA_HOST.
# OLLAMA_HOST=http://localhost:11434

# Telegram channel. Required for telegram-once, telegram-cron-smoke, or persistent Telegram gateway usage.
# AGENTOS_TELEGRAM_BOT_TOKEN=
# AGENTOS_TELEGRAM_CHAT_ID=

# Feishu channel. Required for feishu-once, feishu-cron-smoke, or persistent Feishu gateway usage.
# Feishu receive uses the Open Platform long-connection WebSocket mode.
# AGENTOS_FEISHU_APP_ID=
# AGENTOS_FEISHU_APP_SECRET=
# AGENTOS_FEISHU_ALLOWED_ID=
# Comma-separated authorized sender ids (open_id / user_id / union_id).
# AGENTOS_FEISHU_RECEIVE_ID_TYPE=chat_id
# Supported values: chat_id, open_id, user_id, union_id
# AGENTOS_FEISHU_API_BASE=https://open.feishu.cn/open-apis

# Workspace paths.
# AGENTOS_AGENT_CONFIG_PATH=$AGENT_HOME/workspace/agent.toml
# AGENTOS_SESSION_DB_PATH=$AGENT_HOME/workspace/agentos.sqlite
# AGENTOS_RUN_STATE_PATH=$AGENT_HOME/workspace/runs/cli-run-1.json
# AGENTOS_CRON_DIR=$AGENT_HOME/workspace/crons

# Diagnostics.
# AGENTOS_CLI_TRACE=0
